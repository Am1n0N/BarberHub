PORT=3001
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/barberhub?schema=public"
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d
FLOUCI_APP_TOKEN=
FLOUCI_APP_SECRET=
KONNECT_API_KEY=

# SMTP email settings (for sending credentials to approved shop owners)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=BarberHub <noreply@barberhub.tn>

# WhatsApp notification (sends credentials via WhatsApp click-to-chat link)
WHATSAPP_NOTIFY=true

# Frontend URL (used in notification links)
APP_URL=http://localhost:3000
